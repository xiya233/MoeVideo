APP_ENV=development
LOG_LEVEL=info
HTTP_ADDR=:8080
DB_PATH=./data/moevideo.db
# REQUIRED: replace with a strong random secret; server refuses placeholder/default values.
JWT_SECRET=replace-with-strong-key
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_ADDR=
RATE_LIMIT_REDIS_PASSWORD=
RATE_LIMIT_REDIS_DB=0
RATE_LIMIT_REDIS_PREFIX=moevideo
RATE_LIMIT_FAIL_CLOSED_PROD=true
RATE_LIMIT_DEV_FALLBACK_MEMORY=true

STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage/local
# Shared temp workspace for import/upload-probe/transcode tasks.
TASK_TEMP_DIR=./data/temp
PUBLIC_BASE_URL=http://localhost:8080
MAX_UPLOAD_MB=2048
UPLOAD_URL_EXPIRES=15m
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
TRANSCODE_POLL_INTERVAL=1s
TRANSCODE_MAX_RETRIES=3
TRANSCODE_PROGRESS_LOG_INTERVAL=5s
IMPORT_POLL_INTERVAL=1s
IMPORT_MAX_RETRIES=3
IMPORT_PROGRESS_LOG_INTERVAL=5s
IMPORT_TORRENT_MAX_MB=2
IMPORT_MAX_SELECTED_FILES=20
IMPORT_BT_ENABLE_UPLOAD=
IMPORT_BT_LISTEN_PORT=51413
IMPORT_BT_ENABLE_PORT_FORWARD=true
IMPORT_BT_READER_READAHEAD_MB=32
IMPORT_BT_SPEED_SMOOTH_WINDOW_SEC=5
YTDLP_BIN=yt-dlp
IMPORT_URL_TIMEOUT_SEC=600
IMPORT_URL_MAX_DURATION_SEC=0
IMPORT_URL_MAX_FILE_MB=0
IMPORT_PAGE_RESOLVER_ENABLED=true
IMPORT_PAGE_RESOLVER_TIMEOUT_SEC=25
IMPORT_PAGE_RESOLVER_MAX_CANDIDATES=20
IMPORT_PAGE_RESOLVER_CMD=bun scripts/page_manifest_resolver.mjs
IMPORT_FORCE_FALLBACK_DOMAINS=

# Admin bootstrap moved to CLI:
# go run ./cmd/admin bootstrap --email admin@example.com --username admin --password your-password

# Enable when STORAGE_DRIVER=s3
# S3_BUCKET=moevideo
# S3_REGION=ap-southeast-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_SESSION_TOKEN=
# S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_BASE_URL=
